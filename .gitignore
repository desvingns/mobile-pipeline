# cmp repo .gitignore
# This is the template repo — actual generated projects have their own .gitignore.

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE local config
.idea/
.vscode/
*.swp
*.swo
*~

# Local notes / scratch
SCRATCH.md
NOTES.local.md

# Per-machine, ephemeral cross-tool scratch (the rest of .ai/ IS tracked)
.ai/local/

# Bootstrap test artifacts
test-output/
smoke-test/

# If a contributor accidentally generates a project inside this repo
# while testing bootstrap, ignore the result so it doesn't pollute git.
.claude/sandbox/
.claude/.cmp-version

# Graphify generated knowledge graph (local; rebuild: graphify update .)
graphify-out/

# Self-improvement loop: raw telemetry (retro digests + lessons.md are tracked)
selfimprove/runs/*.jsonl
